# Normalize EOL for all files that Git considers text files.
* text=auto eol=lf
*.png filter=lfs diff=lfs merge=lfs -text
*.skel filter=lfs diff=lfs merge=lfs -text
addons/**/*.dll filter=lfs diff=lfs merge=lfs -text
addons/**/*.exp filter=lfs diff=lfs merge=lfs -text
addons/**/*.lib filter=lfs diff=lfs merge=lfs -text
